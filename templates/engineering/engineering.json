  "newRulePrefixProcess": {
    "selfRegister": {
      "description": "项目特有前缀可自注册，owner 填业务域 Owner",
      "allowedCategoryPatterns": ["coding-*", "domain-*"]
    },
    "requiresApproval": {
      "description": "跨项目通用前缀需架构 Owner 审批后注册",
      "allowedCategoryPatterns": ["general", "architecture", "quality", "delivery", "learning"]
    }
