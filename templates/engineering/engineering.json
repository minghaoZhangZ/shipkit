  "metrics": {
    "ledgerFile": "50-经验沉淀/指标台账.jsonl",
    "sopPromotionSignals": {
      "minOccurrences": 3,
      "minAffectedChanges": 2,
      "sourceCounters": [
        "selfReviewIssuesFound",
        "reviewBlockers",
        "verificationFailedRounds",
        "sopCandidatesCreated"
      ]
    },
    "notes": "当同类问题在多个 change 中重复出现时，结合这些指标判断是否晋升为 SOP。"
